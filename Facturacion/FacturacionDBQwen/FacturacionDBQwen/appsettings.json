{
  "exclude": [
    "**/bin",
    "**/bower_components",
    "**/jspm_packages",
    "**/node_modules",
    "**/obj",
    "**/platforms"
  ]
}
{
  // Configuración de la cadena de conexión a SQL Server
  "ConnectionStrings": {
    // Server: dirección del servidor SQL Server (localhost = tu PC)
    // Database: nombre de la base de datos que se creará
    // User Id: usuario de SQL Server (sa = administrador)
    // Password: contraseña del usuario
    // TrustServerCertificate: permite conexiones sin validar certificado (solo desarrollo)
    "DefaultConnection": "Server=localhost;Database=SistemaFacturacionDB;User Id=sa;Password=TuPassword123;TrustServerCertificate=True;Encrypt=False;"
  },

  // Configuración de logging (registro de eventos)
  "Logging": {
    // Nivel de log para Entity Framework
    // Information = muestra información general
    // Warning = solo advertencias
    // Error = solo errores
    "Microsoft.EntityFrameworkCore": "Information"
  },

  // Configuración de la aplicación
  "AppSettings": {
    // Título que aparecerá en la ventana principal
    "TituloAplicacion": "Sistema de Facturación v1.0",
    // Tiempo de sesión en minutos (0 = sin límite)
    "TiempoSesionMinutos": 30
  }
}
